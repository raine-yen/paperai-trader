# Copy this file to .env.local and fill in the values

# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Secret used by Vercel Cron to authorize tick jobs (any long random string)
CRON_SECRET=change-me-to-a-long-random-string

# Public URL of your app (used in docs / signup emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
